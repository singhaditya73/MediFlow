        "# CELL 4.5: PDF Report Generation Function\n",
        "print(\"\\n--- CELL 4.5: Defining PDF Report Generation ---\")\n",
        "\n",
        "# Install ReportLab if needed\n",
        "!pip install -q reportlab\n",
        "\n",
        "# Import ReportLab components\n",
        "from reportlab.lib.pagesizes import letter\n",
        "from reportlab.lib import colors\n",
        "from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle\n",
        "from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle\n",
        "from reportlab.lib.units import inch\n",
        "\n",
        "def create_medical_report_pdf(data, output_path):\n",
        "    \"\"\"Create a formatted PDF report from the extracted medical data\"\"\"\n",
        "    doc = SimpleDocTemplate(output_path, pagesize=letter)\n",
        "    styles = getSampleStyleSheet()\n",
        "\n",
        "    # Create custom styles\n",
        "    title_style = styles[\"Heading1\"]\n",
        "    title_style.alignment = 1  # Center alignment\n",
        "    section_style = styles[\"Heading3\"]\n",
        "\n",
        "    # Content list\n",
        "    content = []\n",
        "\n",
        "    # Add hospital name as title\n",
        "    hospital = data['report_meta'].get('hospital', 'Medical Report')\n",
        "    content.append(Paragraph(hospital, title_style))\n",
        "    content.append(Spacer(1, 0.25*inch))\n",
        "\n",
        "    # Add report date\n",
        "    report_date = data['report_meta'].get('date', '')\n",
        "    if report_date:\n",
        "        content.append(Paragraph(f\"Report Date: {report_date}\", styles[\"Heading2\"]))\n",
        "        content.append(Spacer(1, 0.2*inch))\n",
        "\n",
        "    # Patient Information Section\n",
        "    content.append(Paragraph(\"PATIENT INFORMATION\", section_style))\n",
        "    content.append(Spacer(1, 0.1*inch))\n",
        "\n",
        "    pt_info = data['patient_info']\n",
        "    patient_data = [\n",
        "        [\"Name:\", pt_info.get('name', 'N/A')],\n",
        "        [\"ID:\", pt_info.get('id', 'N/A')],\n",
        "        [\"Gender:\", pt_info.get('gender', 'N/A')],\n",
        "        [\"Age:\", pt_info.get('age', pt_info.get('birthDate', 'N/A'))]\n",
        "    ]\n",
        "\n",
        "    # Create patient info table\n",
        "    patient_table = Table(patient_data, colWidths=[1.5*inch, 4*inch])\n",
        "    patient_table.setStyle(TableStyle([\n",
        "        ('BACKGROUND', (0, 0), (0, -1), colors.lightgrey),\n",
        "        ('GRID', (0, 0), (-1, -1), 0.5, colors.grey),\n",
        "    ]))\n",
        "    content.append(patient_table)\n",
        "    content.append(Spacer(1, 0.25*inch))\n",
        "\n",
        "    # Diagnoses/Conditions Section\n",
        "    if data['conditions']:\n",
        "        content.append(Paragraph(\"DIAGNOSES\", section_style))\n",
        "        content.append(Spacer(1, 0.1*inch))\n",
